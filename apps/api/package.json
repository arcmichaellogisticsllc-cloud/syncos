{
  "name": "@syncos/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:deps": "npm run build -w @syncos/auth && npm run build -w @syncos/database && npm run build -w @syncos/events && npm run build -w @syncos/permissions && npm run build -w @syncos/shared",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "npm run build:deps && nest start --watch",
    "start": "node dist/main.js",
    "build": "npm run clean && npm run build:deps && nest build",
    "validate:env": "node scripts/validate-env.js",
    "smoke:security": "node scripts/security-smoke.js",
    "smoke:sprint1": "node scripts/sprint1-smoke.js",
    "smoke:sprint2": "node scripts/sprint2-smoke.js",
    "smoke:sprint3": "node scripts/sprint3-smoke.js",
    "smoke:sprint4": "node scripts/sprint4-smoke.js",
    "smoke:sprint5": "node scripts/sprint5-smoke.js",
    "smoke:sprint6": "node scripts/sprint6-smoke.js",
    "smoke:sprint7": "node scripts/sprint7-smoke.js",
    "smoke:sprint8": "node scripts/sprint8-smoke.js",
    "smoke:sprint9": "node scripts/sprint9-smoke.js",
    "smoke:sprint10": "node scripts/sprint10-smoke.js",
    "smoke:sprint11": "node scripts/sprint11-smoke.js",
    "smoke:sprint12": "node scripts/sprint12-smoke.js",
    "smoke:sprint13": "node scripts/sprint13-smoke.js",
    "smoke:sprint14": "node scripts/sprint14-smoke.js",
    "smoke:intelligence": "node scripts/intelligence-smoke.js",
    "smoke:organization": "node scripts/organization-smoke.js",
    "smoke:contact": "node scripts/contact-smoke.js",
    "smoke:relationship": "node scripts/relationship-smoke.js",
    "smoke:candidate": "node scripts/candidate-smoke.js",
    "smoke:opportunity": "node scripts/opportunity-smoke.js",
    "smoke:coverage": "node scripts/coverage-smoke.js",
    "smoke:project-handoff": "node scripts/project-handoff-smoke.js",
    "typecheck": "npm run build:deps && tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@syncos/auth": "file:../../packages/auth",
    "@syncos/database": "file:../../packages/database",
    "@syncos/events": "file:../../packages/events",
    "@syncos/permissions": "file:../../packages/permissions",
    "@syncos/shared": "file:../../packages/shared",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "typescript": "^5.5.4"
  }
}
