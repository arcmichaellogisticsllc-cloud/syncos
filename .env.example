# Local development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/syncos
PORT=3000
AUTH_JWT_SECRET=replace-with-local-dev-secret
ALLOW_DEV_HEADER_AUTH=false
NEXT_PUBLIC_ALLOW_DEV_SESSION_PANEL=false
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3001
SYNCOS_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Local E2E testing
CI=
E2E_DATABASE_URL=postgres://postgres:postgres@localhost:5432/syncos_e2e

# Staging placeholders
# Store staging values in the provider secret manager, not in committed env files.
STAGING_DATABASE_URL=<set-in-provider-secret-manager>
STAGING_AUTH_JWT_SECRET=<set-in-provider-secret-manager>
STAGING_API_BASE_URL=<staging-api-url>
STAGING_WEB_BASE_URL=<staging-web-url>
# Do not run seed:e2e-demo against shared staging unless the environment is explicitly demo-only.
# Developer header auth and session panels must remain disabled in staging.
