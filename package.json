    "cash-application:smoke": "npm run smoke:cash-application -w @syncos/api",
    "collections:smoke": "npm run smoke:collections -w @syncos/api",
    "contractor-payable:smoke": "npm run smoke:contractor-payable -w @syncos/api",
    "payroll:smoke": "npm run smoke:payroll -w @syncos/api",
    "payment-execution:smoke": "npm run smoke:payment-execution -w @syncos/api",
    "bank-reconciliation:smoke": "npm run smoke:bank-reconciliation -w @syncos/api",
    "accounting-export:smoke": "npm run smoke:accounting-export -w @syncos/api",
    "release:validate": "bash scripts/release-validation.sh"
