{
  "name": "syncos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @syncos/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "node --test tests/*.test.js",
    "db:migrate": "npm run migrate -w @syncos/database",
    "db:seed": "npm run seed -w @syncos/database",
    "db:verify": "npm run verify:migrations -w @syncos/database",
    "security:smoke": "npm run smoke:security -w @syncos/api",
    "sprint1:smoke": "npm run smoke:sprint1 -w @syncos/api",
    "sprint2:smoke": "npm run smoke:sprint2 -w @syncos/api",
    "sprint3:smoke": "npm run smoke:sprint3 -w @syncos/api",
    "sprint4:smoke": "npm run smoke:sprint4 -w @syncos/api",
    "sprint5:smoke": "npm run smoke:sprint5 -w @syncos/api",
    "sprint6:smoke": "npm run smoke:sprint6 -w @syncos/api",
    "sprint7:smoke": "npm run smoke:sprint7 -w @syncos/api",
    "sprint8:smoke": "npm run smoke:sprint8 -w @syncos/api",
    "sprint9:smoke": "npm run smoke:sprint9 -w @syncos/api",
    "sprint10:smoke": "npm run smoke:sprint10 -w @syncos/api",
    "sprint11:smoke": "npm run smoke:sprint11 -w @syncos/api",
    "sprint12:smoke": "npm run smoke:sprint12 -w @syncos/api",
    "sprint13:smoke": "npm run smoke:sprint13 -w @syncos/api",
    "sprint14:smoke": "npm run smoke:sprint14 -w @syncos/api",
    "intelligence:smoke": "npm run smoke:intelligence -w @syncos/api",
    "organization:smoke": "npm run smoke:organization -w @syncos/api",
    "contact:smoke": "npm run smoke:contact -w @syncos/api",
    "relationship:smoke": "npm run smoke:relationship -w @syncos/api",
    "candidate:smoke": "npm run smoke:candidate -w @syncos/api",
    "opportunity:smoke": "npm run smoke:opportunity -w @syncos/api",
    "coverage:smoke": "npm run smoke:coverage -w @syncos/api",
    "project-handoff:smoke": "npm run smoke:project-handoff -w @syncos/api",
    "project:smoke": "npm run smoke:project -w @syncos/api",
    "work-order:smoke": "npm run smoke:work-order -w @syncos/api",
    "production:smoke": "npm run smoke:production -w @syncos/api",
    "qc:smoke": "npm run smoke:qc -w @syncos/api",
    "billable:smoke": "npm run smoke:billable -w @syncos/api",
    "settlement:smoke": "npm run smoke:settlement -w @syncos/api",
